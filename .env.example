# Your Amazon Associates tracking ID, e.g. "yourtag-20"
AMAZON_ASSOCIATE_TAG=YOURTAG-20

# Your production domain, used in the sitemap, robots.txt, and OpenGraph tags
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Admin dashboard (/admin) ---------------------------------------------

# HTTP Basic Auth password required to reach /admin and /api/admin.
# Username is fixed as "admin". If unset, falls back to Simple@#123.
ADMIN_PASSWORD=Simple@#123

# GitHub personal access token (repo write scope) the admin dashboard uses
# to commit guide/product edits straight to this repo — Vercel then
# auto-deploys the change, same as running push.sh. Required for Edit/
# Delete/Create to work; without it /admin will load but show a setup
# notice instead of data. Set this locally in .env.local AND in your
# Vercel project's Settings -> Environment Variables.
GITHUB_TOKEN=

# Only needed if this ever moves to a different repo/branch — defaults
# already match this project (summit3platforms-sys/amznaff, main).
GITHUB_OWNER=summit3platforms-sys
GITHUB_REPO=amznaff
GITHUB_BRANCH=main
